# Don't ship local-only artifacts into the image — they'll be regenerated.
.venv/
__pycache__/
**/__pycache__/
*.pyc
mlruns/
mlflow.db
mlartifacts/

# Reports are deliverable docs, not needed at runtime for the UI demo.
# Comment the next line out if you want them inside the container too.
reports/

# Editor & OS junk.
.DS_Store
.idea/
.vscode/
*.swp
~$*

# Git metadata.
.git/
.gitignore
.github/

# Processed data (regenerated by data_loader on demand).
data/processed/

# Azure deploy scripts are operator-side, not container-side.
azure/

# Docker meta that should not recurse into itself.
Dockerfile
docker-compose.yml
.dockerignore
